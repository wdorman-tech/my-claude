{
  "autoUpdatesChannel": "latest",
  "effortLevel": "max",
  "enabledPlugins": {
    "vercel@claude-plugins-official": true
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/notify-windows.sh\"",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt"
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/notify-windows.sh\"",
            "type": "command"
          }
        ],
        "matcher": "idle_prompt"
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/format-on-save.sh\"",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/block-sensitive-files.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      },
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "bash \"$HOME/.claude/scripts/dash-status.sh\"",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "skipAutoPermissionPrompt": true,
  "skipDangerousModePermissionPrompt": true,
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "voiceEnabled": true
}